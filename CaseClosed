using EvidenceExamMVCCodeFirst.Models;
using System;
using System.Data.Entity;
using System.IO;
using System.Linq;
using System.Web;
using System.Web.Mvc;

namespace EvidenceExamMVCCodeFirst.Controllers
{
    public class StudentsController : Controller
    {
        AppDbContext db = new AppDbContext();

        SelectList DepList(int? id = null)
        {
            return new SelectList(db.Departments, "Id", "DepartmentName", id);
        }

        string SavePic(HttpPostedFileBase pic, string oldPic = null)
        {
            if (pic == null || pic.ContentLength == 0)
                return oldPic;

            string folder = Server.MapPath("~/Images/");
            Directory.CreateDirectory(folder);

            string file = Guid.NewGuid() + Path.GetExtension(pic.FileName);
            pic.SaveAs(Path.Combine(folder, file));
            return "/Images/" + file;
        }

        void AddSubjects(Student s, StudentVM vm)
        {
            if (vm.Subjects == null)
                return;

            foreach (var x in vm.Subjects)
            {
                if (!string.IsNullOrWhiteSpace(x.Course))
                    s.Subjects.Add(new Subject { Course = x.Course, Credit = x.Credit });
            }
        }

        public ActionResult Index()
        {
            var data = db.Students
                .Include(x => x.Department)
                .Include(x => x.Subjects)
                .ToList();

            return View(data);
        }

        public ActionResult Create()
        {
            return View(new StudentVM
            {
                AdmissionDate = DateTime.Today,
                IsActive = true,
                DepartmentList = DepList()
            });
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public ActionResult Create(StudentVM vm)
        {
            if (!ModelState.IsValid)
            {
                return Content("Invalid data");
            }

            var s = new Student
            {
                Name = vm.Name,
                AdmissionDate = vm.AdmissionDate,
                IsActive = vm.IsActive,
                ImageUrl = SavePic(vm.Picture),
                DepartmentId = vm.DepartmentId
            };

            AddSubjects(s, vm);
            db.Students.Add(s);
            db.SaveChanges();
            return Content("Saved");
        }

        public ActionResult Edit(int id)
        {
            var s = db.Students.Include(x => x.Subjects).FirstOrDefault(x => x.Id == id);

            if (s == null)
                return HttpNotFound();

            return View(new StudentVM
            {
                Id = s.Id,
                Name = s.Name,
                AdmissionDate = s.AdmissionDate,
                IsActive = s.IsActive,
                ImageUrl = s.ImageUrl,
                DepartmentId = s.DepartmentId,
                DepartmentList = DepList(s.DepartmentId),
                Subjects = s.Subjects.ToList()
            });
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public ActionResult Edit(StudentVM vm)
        {
            if (!ModelState.IsValid)
            {
                return Content("Invalid data");
            }

            var s = db.Students.Find(vm.Id);

            if (s == null)
                return HttpNotFound();

            s.Name = vm.Name;
            s.AdmissionDate = vm.AdmissionDate;
            s.IsActive = vm.IsActive;
            s.ImageUrl = SavePic(vm.Picture, vm.ImageUrl);
            s.DepartmentId = vm.DepartmentId;

            db.Subjects.RemoveRange(db.Subjects.Where(x => x.StudentId == s.Id));
            AddSubjects(s, vm);
            db.SaveChanges();

            return Content("Updated");
        }

        [HttpPost]
        public ActionResult Delete(int id)
        {
            var s = db.Students.Find(id);

            if (s != null)
            {
                db.Subjects.RemoveRange(db.Subjects.Where(x => x.StudentId == id));
                db.Students.Remove(s);
                db.SaveChanges();
            }

            return Content("Deleted");
        }
    }
}
