@model EvidenceExamMVCCodeFirst.Models.StudentVM

@Html.HiddenFor(x => x.Id)
@Html.HiddenFor(x => x.ImageUrl)

Name: @Html.TextBoxFor(x => x.Name)<br />
Date: @Html.TextBoxFor(x => x.AdmissionDate, "{0:yyyy-MM-dd}", new { type = "date" })<br />
Active: @Html.CheckBoxFor(x => x.IsActive)<br />
Department: @Html.DropDownListFor(x => x.DepartmentId, Model.DepartmentList, "--Select--")<br />
Photo: <input type="file" name="Picture" /><br />

@if (!string.IsNullOrEmpty(Model.ImageUrl))
{
    <img src="@Model.ImageUrl" width="60" />
}

<h4>Subjects</h4>
<button type="button" id="add">Add</button>
<div id="subs">
    @if (Model.Subjects != null && Model.Subjects.Count > 0)
    {
        for (int i = 0; i < Model.Subjects.Count; i++)
        {
            <p>
                <input name="Subjects[@i].Course" value="@Model.Subjects[i].Course" placeholder="Course" />
                <input name="Subjects[@i].Credit" value="@Model.Subjects[i].Credit" type="number" placeholder="Credit" />
                <button type="button" class="rem">X</button>
            </p>
        }
    }
    else
    {
        <p>
            <input name="Subjects[0].Course" placeholder="Course" />
            <input name="Subjects[0].Credit" type="number" placeholder="Credit" />
            <button type="button" class="rem">X</button>
        </p>
    }
</div>

<input type="submit" value="@ViewBag.Button" />
@Html.ActionLink("Back", "Index")

<script>
    function row(i) {
        return '<p>'
            + '<input name="Subjects[' + i + '].Course" placeholder="Course" /> '
            + '<input name="Subjects[' + i + '].Credit" type="number" placeholder="Credit" /> '
            + '<button type="button" class="rem">X</button>'
            + '</p>';
    }

    function renumber() {
        var rows = document.querySelectorAll('#subs p');

        for (var i = 0; i < rows.length; i++) {
            rows[i].querySelector('[name$=".Course"]').name = 'Subjects[' + i + '].Course';
            rows[i].querySelector('[name$=".Credit"]').name = 'Subjects[' + i + '].Credit';
        }
    }

    document.addEventListener('click', function (e) {
        if (e.target.id == 'add') {
            var subs = document.getElementById('subs');
            subs.insertAdjacentHTML('beforeend', row(subs.querySelectorAll('p').length));
        }

        if (e.target.classList.contains('rem')) {
            var rows = document.querySelectorAll('#subs p');

            if (rows.length > 1) {
                e.target.parentNode.remove();
                renumber();
            }
        }
    });

    function clearForm(result) {
        if (result != 'Saved')
            return;

        document.querySelector('form').reset();
        document.getElementById('subs').innerHTML = row(0);
    }
</script>
