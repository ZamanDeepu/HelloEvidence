    <tbody>
        @foreach (var s in Model)
        {
            <tr id="r@s.Id">
                <td>
                    @if (!string.IsNullOrEmpty(s.ImageUrl))
                    {
                        <img src="@s.ImageUrl" width="50" />
                    }
                </td>
                <td>@s.Name</td>
                <td>@s.AdmissionDate</td>
                <td>@s.IsActive</td>
                <td>@s.Department.DepartmentName</td>
                <td>@string.Join(", ", s.Subjects.Select(x => x.Course + " " + x.Credit))</td>
                <td>
                    @Html.ActionLink("Edit", "Edit", new { id = s.Id })
                    <a href="#" onclick="doDelete(@s.Id, this); return false;">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<script>
    function doDelete(id, el) {
        var row = el.closest('tr');
        var xhr = new XMLHttpRequest();
        xhr.open('POST', '/Students/Delete/' + id);
        xhr.onload = function () {
            row.remove();
            document.getElementById('msg').innerHTML = xhr.responseText;
        };
        xhr.send();
    }
</script>
