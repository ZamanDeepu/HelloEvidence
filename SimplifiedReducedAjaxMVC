4) Controllers/StudentsController.cs

using StudentMasterDetails.Models;
using System;
using System.Data.Entity;
using System.IO;
using System.Linq;
using System.Web;
using System.Web.Mvc;

namespace StudentMasterDetails.Controllers
{
    public class StudentsController : Controller
    {
        StudentMasterDetailsDBEntities db = new StudentMasterDetailsDBEntities();

        SelectList D(int? id = null) =>
            new SelectList(db.Departments.ToList(), "Id", "DepartmentName", id);

        string Pic(HttpPostedFileBase p, string old = null)
        {
            if (p == null || p.ContentLength == 0) return old;
            string f = Guid.NewGuid() + Path.GetExtension(p.FileName);
            string dir = Server.MapPath("~/Images/");
            Directory.CreateDirectory(dir);
            p.SaveAs(Path.Combine(dir, f));
            return "/Images/" + f;
        }

        void AddSubjects(Student s, StudentVM v)
        {
            if (v.Subjects == null) return;

            foreach (var x in v.Subjects)
                if (!string.IsNullOrWhiteSpace(x.Course))
                    s.Subjects.Add(new Subject { Course = x.Course, Credit = x.Credit });
        }

        StudentVM VM(Student s) => new StudentVM
        {
            Id = s.Id,
            Name = s.Name,
            Age = s.Age,
            AdmissionDate = s.AdmissionDate,
            IsActive = s.IsActive,
            ImageUrl = s.ImageUrl,
            DepartmentId = s.DepartmentId,
            DepartmentList = D(s.DepartmentId),
            Subjects = s.Subjects.ToList()
        };

        public ActionResult Index() =>
            View(db.Students.Include(x => x.Department)
                            .Include(x => x.Subjects).ToList());

        public ActionResult Create() =>
            View(new StudentVM { AdmissionDate = DateTime.Today, DepartmentList = D() });

        [HttpPost, ValidateAntiForgeryToken]
        public ActionResult Create(StudentVM v)
        {
            if (!ModelState.IsValid)
            {
                v.DepartmentList = D(v.DepartmentId);
                return View(v);
            }

            var s = new Student
            {
                Name = v.Name,
                Age = v.Age,
                AdmissionDate = v.AdmissionDate,
                IsActive = v.IsActive,
                ImageUrl = Pic(v.Picture),
                DepartmentId = v.DepartmentId
            };

            AddSubjects(s, v);
            db.Students.Add(s);
            db.SaveChanges();
            return Content("Saved");
        }

        public ActionResult Edit(int id)
        {
            var s = db.Students.Find(id);
            return s == null ? HttpNotFound() : (ActionResult)View(VM(s));
        }

        [HttpPost, ValidateAntiForgeryToken]
        public ActionResult Edit(StudentVM v)
        {
            if (!ModelState.IsValid)
            {
                v.DepartmentList = D(v.DepartmentId);
                return View(v);
            }

            var s = db.Students.Find(v.Id);
            if (s == null) return HttpNotFound();

            s.Name = v.Name;
            s.Age = v.Age;
            s.AdmissionDate = v.AdmissionDate;
            s.IsActive = v.IsActive;
            s.ImageUrl = Pic(v.Picture, v.ImageUrl);
            s.DepartmentId = v.DepartmentId;

            db.Subjects.RemoveRange(db.Subjects.Where(x => x.StudentId == s.Id));
            AddSubjects(s, v);

            db.SaveChanges();
            return Content("Updated");
        }

        [HttpPost]
        public ActionResult Delete(int id)
        {
            var s = db.Students.Find(id);
            if (s != null)
            {
                db.Students.Remove(s);
                db.SaveChanges();
            }
            return Content("Deleted");
        }
    }
}


