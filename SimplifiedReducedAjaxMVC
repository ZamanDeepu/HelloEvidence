6) Views/Students/Create.cshtml

@model StudentMasterDetails.Models.StudentVM
@{ ViewBag.Button = "Save"; }

<h2>Create</h2>
<div id="msg"></div>

@using (Ajax.BeginForm("Create", "Students", null,
    new AjaxOptions { HttpMethod = "POST", UpdateTargetId = "msg", OnSuccess = "clearForm" },
    new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary()
    @Html.Partial("_Form", Model)
}

@section scripts{
<script>
function clearForm() {
    $('form')[0].reset();
    $('#body').html(
        '<tr>' +
        '<td><input name="Subjects[0].Course" class="form-control"/></td>' +
        '<td><input name="Subjects[0].Credit" value="3" type="number" class="form-control"/></td>' +
        '<td><button type="button" class="rem">X</button></td>' +
        '</tr>'
    );
}

function renumber() {
    $('#body tr').each(function (i) {
        $(this).find('[name$=".Course"]').attr('name', 'Subjects[' + i + '].Course');
        $(this).find('[name$=".Credit"]').attr('name', 'Subjects[' + i + '].Credit');
    });
}

$(document).on('click', '#add', function () {
    var i = $('#body tr').length;
    $('#body').append('<tr><td><input name="Subjects[' + i + '].Course" class="form-control" /></td><td><input name="Subjects[' + i + '].Credit" value="3" type="number" class="form-control" /></td><td><button type="button" class="rem">X</button></td></tr>');
});

$(document).on('click', '.rem', function () {
    if ($('#body tr').length > 1) {
        $(this).closest('tr').remove();
        renumber();
    }
});
</script>
}


