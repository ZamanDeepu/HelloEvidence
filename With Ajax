@model StudentMasterDetails.Models.StudentVM
@{ ViewBag.Title = "Add Student"; }
<h2>Add Student</h2>
<div id="msg"></div>
@using (Ajax.BeginForm ("Create", "Students", new AjaxOptions
{
    HttpMethod = "POST",
    UpdateTargetId = "msg",
    InsertionMode = InsertionMode.Replace,
    OnComplete = "clearAll"
}))
{
    @Html.AntiForgeryToken()
    <div class="form-group">
        @Html.LabelFor(m => m.Name)
        @Html.TextBoxFor(m => m.Name, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.DepartmentId, "Department")
        @Html.DropDownListFor(m => m.DepartmentId, Model.DepartmentList, "--Select--", new { @class = "form-control" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.AdmissionDate)
        @Html.TextBoxFor(m => m.AdmissionDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.RegistrationFee)
        @Html.TextBoxFor(m => m.RegistrationFee, new { @class = "form-control", type = "number", step = "0.01" })
    </div>
    <div class="form-group">
        @Html.CheckBoxFor(m => m.IsActive) <label>Active Student</label>
    </div>
    <div class="form-group">
        <label>Photo</label>
        <input type="file" name="Picture" accept="image/*" id="picInput" />
        <img id="preview" src="#" style="display:none;width:60px;height:60px;border-radius:50%" />
    </div>
    <hr />
    <h4>Subjects</h4>
    @Html.Partial("_SubjectRows", Model.Subjects)
    <button type="submit" class="btn btn-primary" style="margin-top:10px">Save</button>
    <a href="@Url.Action("Index")" class="btn btn-default">Cancel</a>
}
@section scripts {
    <script type="text/javascript">
        $("#form0").attr("enctype", "multipart/form-data")
        function clearAll() {
            $("#form0").trigger("reset");
        }

        $('#picInput').change(function () {
            var r = new FileReader();
            r.onload = function (e) { $('#preview').attr('src', e.target.result).show(); };
            r.readAsDataURL(this.files[0]);
        });

        function reIdx() {
            $('#subBody tr.sr').each(function (i) {
                $(this).find('[name*=Course]').attr('name', 'Subjects[' + i + '].Course');
                $(this).find('[name*=Credit]').attr('name', 'Subjects[' + i + '].Credit');
            });
        }
        $('#addRow').click(function () {
            var i = $('#subBody tr.sr').length;
            $('#subBody').append(
                '<tr class="sr"><td><input name="Subjects[' + i + '].Course" class="form-control"/></td>' +
                '<td><input name="Subjects[' + i + '].Credit" type="number" value="3" class="form-control"/></td>' +
                '<td><button type="button" class="rem btn btn-danger btn-xs">X</button></td></tr>');
        });
        $(document).on('click', '.rem', function () {
            if ($('#subBody tr.sr').length > 1) { $(this).closest('tr').remove(); reIdx(); }
            else alert('At least 1 subject required');
        });
    </script>
}


