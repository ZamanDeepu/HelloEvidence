@model IEnumerable<StudentMasterDetails.Models.Student>
@{ ViewBag.Title = "Students"; }
<h2>Students</h2>
<div id="msg"></div>
<a href="@Url.Action("Create")" class="btn btn-primary" style="margin-bottom:8px">+ Add Student</a>
<table class="table table-bordered">
  <tr><th>Photo</th><th>Name</th><th>Dept</th><th>Date</th><th>Fee</th><th>Active</th><th>Subjects</th><th></th></tr>
  @foreach (var s in Model) {
  <tr id="row-@s.Id">
    <td>@if (!string.IsNullOrEmpty(s.ImageUrl)) {
      <img src="@s.ImageUrl" width="44" height="44" style="border-radius:50%;object-fit:cover" />}</td>
    <td>@s.Name</td>
    <td>@(s.Department != null ? s.Department.DepartmentName : "-")</td>
    <td>@s.AdmissionDate.ToString("dd/MM/yyyy")</td>
    <td>@s.RegistrationFee.ToString("N2")</td>
    <td>@(s.IsActive ? "Yes" : "No")</td>
    <td>@foreach (var sub in s.Subjects) {
      <span class="label label-info">@sub.Course</span>}</td>
    <td>
      <a href="@Url.Action("Details", new { id=s.Id })" class="btn btn-xs btn-info">View</a>
      <a href="@Url.Action("Edit",    new { id=s.Id })" class="btn btn-xs btn-warning">Edit</a>
      @using (Html.BeginForm("Delete","Students",new{id=s.Id},FormMethod.Post,
              new{style="display:inline",id="df"+s.Id})) {
        @Html.AntiForgeryToken()
        <button type="button" onclick="delStu(@s.Id)"
                class="btn btn-xs btn-danger">Del</button>}
    </td>
  </tr>}
</table>
@section scripts {
<script>
function delStu(id) {
    if (!confirm('Delete?')) return;
    $.ajax({
        type: 'POST',
        url: '@Url.Action("Delete","Students")/' + id,
        data: $('#df' + id).serialize(),
        success: function () { $('#row-' + id).remove(); }
    });
}
</script>}

